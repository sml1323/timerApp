{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "strict": true,
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": "."
  },
  "include": [
    "src/platform/tauri/sql-client.ts",
    "src/domain/sessions/session.ts",
    "src/features/session/session-flow.ts",
    "src/features/session/state/sessionStore.ts",
    "src/domain/goals/weekly-goal.ts",
    "src/domain/goals/weekly-goal-mappers.ts",
    "src/domain/goals/weekly-goal-schema.ts",
    "src/domain/goals/weekly-goal-repository.ts",
    "src/shared/lib/dates.ts",
    "src/shared/lib/result.ts",
    "src/shared/lib/errors.ts",
    "src/platform/runtime/runtime-detect.ts",
    "src/platform/browser/goal-adapter.ts",
    "src/platform/browser/in-memory-goal-adapter.ts",
    "src/features/goals/goal-service.ts"
  ]
}
